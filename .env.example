# Copie este arquivo para ".env" e preencha com valores reais antes de publicar.

SECRET_KEY=troque-esta-chave-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# E-mail para notificação de confirmações de presença (RSVP)
# Deixe EMAIL_BACKEND como console.EmailBackend para testar sem enviar de verdade
# (os e-mails aparecem no terminal onde o runserver está rodando).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_DESTINATARIO_CONFIRMACAO=

# Para usar Gmail de verdade, troque a linha acima para:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# e gere uma senha de app em https://myaccount.google.com/apppasswords
